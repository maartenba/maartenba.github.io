---
import type { CollectionEntry } from "astro:content";
import IconEdit from "@/assets/icons/IconEdit.svg";
import { SITE } from "@/config";

export interface Props {
  hideEditPost?: CollectionEntry<"blog">["data"]["hideEditPost"];
  class?: string;
  post?: CollectionEntry<"blog">;
  /** Direct file path for non-blog pages (relative to repo root) */
  filePath?: string;
}

const { hideEditPost, post, filePath, class: className = "" } = Astro.props;

const resolvedPath = filePath ?? post?.filePath ?? "";
const href = `${SITE.editPost.url}${resolvedPath}`;
const showEditPost =
  SITE.editPost.enabled && !hideEditPost && href.trim() !== "" && resolvedPath !== "";
---

{
  showEditPost && (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class:list={[
        "inline-flex items-center gap-1.5 rounded-full border border-accent/40 bg-accent/10 px-3 py-1 text-sm font-medium text-accent hover:bg-accent/20 transition-colors",
        className,
      ]}
    >
      <IconEdit class="inline-block shrink-0" />
      <span>{SITE.editPost.text}</span>
    </a>
  )
}
