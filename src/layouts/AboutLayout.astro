---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import EditPost from "@/components/EditPost.astro";
import EthicalAd from "@/components/EthicalAd.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;

// Derive the source file path from the current URL
// e.g., /about -> src/pages/about.md, /talks-presentations -> src/pages/talks-presentations.md
const slug = Astro.url.pathname.replace(/^\/|\/$/g, "");
const filePath = `src/pages/${slug}.md`;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content">
    <!-- Page header banner -->
    <div class="page-hero mx-auto max-w-app px-4">
      <div class="mb-8 rounded-xl bg-gradient-to-br from-[#1e3a5f] via-[#2563eb] to-[#7c3aed] px-6 py-8 sm:px-8 sm:py-10 relative overflow-hidden dark:from-[#1a1b2e] dark:via-[#1e40af] dark:to-[#5b21b6]">
        <div class="absolute -top-16 -right-16 h-56 w-56 rounded-full bg-white/[0.06]"></div>
        <div class="absolute -bottom-10 -left-10 h-36 w-36 rounded-full bg-white/[0.04]"></div>
        <h1 class="relative text-2xl font-bold text-white tracking-wider sm:text-3xl">{frontmatter.title}</h1>
      </div>
      <EthicalAd />
    </div>
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <slot />
      <EditPost filePath={filePath} class="mt-8" />
    </section>
  </main>
  <Footer />
</Layout>
